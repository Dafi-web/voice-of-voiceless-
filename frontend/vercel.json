{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://voice-of-voiceless-1.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://voice-of-voiceless-1.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
