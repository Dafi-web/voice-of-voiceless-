# Production builds use this to call Render directly (required for Vercel + Render split deploy).
# No trailing slash. Also set in Vercel dashboard if you override the default.
VITE_API_URL=https://voice-of-voiceless-1.onrender.com

# Public gallery uploads — browser uploads directly to Cloudinary (permanent public URLs)
VITE_CLOUDINARY_CLOUD_NAME=dcmwonevb
VITE_CLOUDINARY_UPLOAD_PRESET=beyond_silence_gallery
