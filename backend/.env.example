ADMIN_PASSWORD=rahwa2026
JWT_SECRET=change-this-to-a-long-random-string
PORT=3001

# MongoDB Atlas — set ONE of these on Render (either name works):
# MONGODB_URI=...   OR   MONGO_URL=...
# If your password contains @ # : / etc., URL-encode it (@ → %40)
# Example: password "yesno@1212" → yesno%401212
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/beyond-silence?retryWrites=true&w=majority

# --- Public media uploads (recommended for production) ---
# Without cloud storage, uploaded images/videos are saved on Render disk. Gallery metadata
# in MongoDB survives redeploys, but files on disk can be lost — users see broken images.
#
# Option A — Cloudinary (easiest, free tier):
# 1. Sign up at https://cloudinary.com
# 2. Dashboard → copy "API environment variable" (looks like cloudinary://key:secret@cloud_name)
# 3. Set on Render:
# CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@your-cloud-name
#
# Option B — Google Cloud Storage:
# 1. Create a bucket with public read access (allUsers → Storage Object Viewer)
# 2. Create a service account with Storage Object Admin, download JSON key
# 3. Set on Render:
# GCS_BUCKET=your-bucket-name
# GCS_PROJECT_ID=your-gcp-project-id
# GCS_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
